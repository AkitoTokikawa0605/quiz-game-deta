;=================================
; 前のキャラ
;=================================


*prev

[iscript]
f.chara_index--;
if (f.chara_index < 0) {
f.chara_index = f.chara_list.length - 1;
}
[endscript]

[jump  target="*update_chara"  storage=""  ]

;=================================
; 次のキャラ
;=================================


*next

[iscript]
f.chara_index++;
if (f.chara_index >= f.chara_list.length) {
f.chara_index = 0;
}
[endscript]

[jump  target="*update_chara"  storage=""  ]

;=================================
; 決定
;=================================


*decide

[iscript]
sf.selected_chara = f.chara_list[f.chara_index];
[endscript]

