*update_chara

[iscript]
if (f.chara_list == undefined) {
f.chara_list = [
"chara1",
"chara2",
"chara3",
"chara4"
];
}
if (f.chara_index == undefined) {
f.chara_index = 0;
}
f.chara_img = f.chara_list[f.chara_index] + ".png";
console.log("index=" + f.chara_index);
console.log("image=" + f.chara_img);
[endscript]

